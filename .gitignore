# Python
__pycache__/
*.py[cod]
*.log
venv/

# Env / secrets — never commit these
.env
*.env
backend/.env.local
.env.*.local

# Node / Frontend
frontend/node_modules/
node_modules/
frontend/dist/
frontend/playwright/.auth/

# Django outputs
staticfiles/
staticfiles/assets/
static/
media/
/media/

# Database — never commit db files or recovery artifacts
*.sqlite3
*.db
*.sqlite3-journal
*.sqlite3-wal
*.sqlite3-shm
db.sqlite3.bad-*
db.sqlite3.corrupt-*
db.sqlite3.locked-*
db.sqlite3.pre-*
recovered.sql

# Aider AI assistant
.aider*
